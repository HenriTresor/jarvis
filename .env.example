# ── LLM — Groq (required) ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── LLM — Cerebras (optional fallback, free tier) ────────────────────────────
# Sign up at https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here
# CEREBRAS_MODEL=llama-3.3-70b   # default

# ── LLM — Google Gemini (optional fallback, free tier) ───────────────────────
# Get key at https://aistudio.google.com — 1M tokens/day free
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash  # default

# ── TTS ──────────────────────────────────────────────────────────────────────
TTS_ENGINE=piper                        # piper | xtts
PIPER_VOICE=en_GB-alan-medium           # any installed Piper voice
SPEAKER_WAV=./jarvis_voice.wav          # 6-second WAV for XTTS voice cloning

# ── STT ──────────────────────────────────────────────────────────────────────
# Run: python3 -c "import sounddevice as sd; print(sd.query_devices())"
STT_DEVICE=0                            # sounddevice input device index

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
# Generate an App Password at: https://myaccount.google.com/apppasswords
# (16-char code — requires 2-Step Verification enabled on the account)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# ── System ────────────────────────────────────────────────────────────────────
SUDO_PASSWORD=your_sudo_password        # used by system tools (volume, etc.)
